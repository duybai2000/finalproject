generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

model User {
  id        String   @id @default(cuid())
  email     String?  @unique
  name      String?
  password  String?
  role      String   @default("USER") // USER, OWNER, or ADMIN
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  rides     RideBooking[]
  rentals   RentalBooking[]
  cars      Car[]
}

model RideBooking {
  id             String   @id @default(cuid())
  pickup         String
  dropoff        String
  pickupLat      Float?
  pickupLng      Float?
  pickupAccuracy Float?
  dropoffLat     Float?
  dropoffLng     Float?
  distanceKm     Float?
  locationCapturedAt DateTime?
  estimatedPrice Int
  distance       String   // legacy: stores schedule label "{startDate} den {endDate}"
  time           String   // legacy: stores duration label "{days} ngay"
  status         String   @default("PENDING") // PENDING, ACCEPTED, COMPLETED, CANCELLED
  paidAt         DateTime?
  createdAt      DateTime @default(now())

  userId         String
  user           User     @relation(fields: [userId], references: [id])
}

model RentalBooking {
  id             String   @id @default(cuid())
  carId          Int
  carName        String
  dateRange      String
  totalPrice     Int
  status         String   @default("PENDING") // PENDING, CONFIRMED, COMPLETED, CANCELLED
  paidAt         DateTime?
  createdAt      DateTime @default(now())

  userId         String
  user           User     @relation(fields: [userId], references: [id])
}

model Car {
  id          Int      @id @default(autoincrement())
  name        String
  type        String
  seats       Int
  auto        Boolean  @default(true)
  dailyRate   Int
  img         String
  description String?
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  ownerId     String?  // null = platform-owned (admin-managed)
  owner       User?    @relation(fields: [ownerId], references: [id])
}

model ContactMessage {
  id        String   @id @default(cuid())
  name      String
  email     String
  message   String
  createdAt DateTime @default(now())
}
