generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

model User {
  id            String   @id @default(cuid())
  email         String?  @unique
  name          String?
  phone         String?
  password      String?
  role          String   @default("USER") // USER, OWNER, DRIVER, or ADMIN
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  rides         RideBooking[] @relation("UserRides")
  drivenRides   RideBooking[] @relation("DriverRides")
  rentals       RentalBooking[]
  cars          Car[]
  ratings       Rating[]      @relation("RatingsByUser")
}

model RideBooking {
  id             String   @id @default(cuid())
  pickup         String
  dropoff        String?
  pickupLat      Float?
  pickupLng      Float?
  pickupAccuracy Float?
  dropoffLat     Float?
  dropoffLng     Float?
  locationCapturedAt DateTime?
  estimatedPrice Int
  distance       String   // legacy: stores schedule label "{startDate} den {endDate}"
  time           String   // legacy: stores duration label "{days} ngay"
  status         String   @default("PENDING") // PENDING, ACCEPTED, COMPLETED, CANCELLED
  paidAt         DateTime?
  createdAt      DateTime @default(now())

  userId         String
  user           User     @relation("UserRides", fields: [userId], references: [id])
  driverId       String?
  driver         User?    @relation("DriverRides", fields: [driverId], references: [id])
  rating         Rating?
}

model RentalBooking {
  id             String   @id @default(cuid())
  carId          Int
  carName        String
  dateRange      String
  totalPrice     Int
  status         String   @default("PENDING") // PENDING, CONFIRMED, COMPLETED, CANCELLED
  paidAt         DateTime?
  createdAt      DateTime @default(now())

  userId         String
  user           User     @relation(fields: [userId], references: [id])
  rating         Rating?
}

model Car {
  id          Int      @id @default(autoincrement())
  name        String
  type        String
  seats       Int
  auto        Boolean  @default(true)
  dailyRate   Int
  img         String
  description String?
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  ownerId     String?  // null = platform-owned (admin-managed)
  owner       User?    @relation(fields: [ownerId], references: [id])
}

model ContactMessage {
  id        String   @id @default(cuid())
  name      String
  email     String
  message   String
  createdAt DateTime @default(now())
}

model Rating {
  id        String   @id @default(cuid())
  score     Int      // 1-5
  comment   String?
  createdAt DateTime @default(now())

  rideId    String?  @unique
  ride      RideBooking?   @relation(fields: [rideId], references: [id], onDelete: Cascade)
  rentalId  String?  @unique
  rental    RentalBooking? @relation(fields: [rentalId], references: [id], onDelete: Cascade)

  raterId   String
  rater     User     @relation("RatingsByUser", fields: [raterId], references: [id])
}
